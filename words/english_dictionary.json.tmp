  "absolute": {
    "input_word": "absolute",
    "greek_translation": "απόλυτος",
    "senses": [
      {
        "part_of_speech": "n",
        "definition": "something that is conceived or that exists independently and not in relation to other things; something that does not depend on anything else and is beyond human control; something that is not relative",
        "examples": [
          "no mortal being can influence the absolute"
        ]
      },
      {
        "part_of_speech": "a",
        "definition": "perfect or complete or pure",
        "examples": [
          "absolute loyalty",
          "absolute silence",
          "absolute truth",
          "absolute alcohol"
        ]
      },
      {
        "part_of_speech": "s",
        "definition": "complete and without restriction or qualification; sometimes used informally as intensifiers",
        "examples": [
          "absolute freedom",
          "an absolute dimwit",
          "a downright lie",
          "out-and-out mayhem",
          "an out-and-out lie",
          "a rank outsider",
          "many right-down vices",
          "got the job through sheer persistence",
          "sheer stupidity"
        ]
      },
      {
        "part_of_speech": "s",
        "definition": "not limited by law",
        "examples": [
          "an absolute monarch"
        ]
      },
      {
        "part_of_speech": "s",
        "definition": "expressing finality with no implication of possible change",
        "examples": [
          "an absolute guarantee to respect the nation's authority"
        ]
      },
      {
        "part_of_speech": "s",
        "definition": "not capable of being violated or infringed",
        "examples": [
          "infrangible human rights"
        ]
      }
    ],
    "status": "ok"
  },
  "absolutely": {
    "input_word": "absolutely",
    "greek_translation": "απολύτως",
    "senses": [
      {
        "part_of_speech": "r",
        "definition": "completely and without qualification; used informally as intensifiers",
        "examples": [
          "an absolutely magnificent painting",
          "a perfectly idiotic idea",
          "you're perfectly right",
          "utterly miserable",
          "you can be dead sure of my innocence",
          "was dead tired",
          "dead right"
        ]
      },
      {
        "part_of_speech": "r",
        "definition": "totally and definitely; without question",
        "examples": [
          "we are absolutely opposed to the idea",
          "he forced himself to lie absolutely still",
          "iron is absolutely necessary"
        ]
      }
    ],
    "status": "ok"
  },
