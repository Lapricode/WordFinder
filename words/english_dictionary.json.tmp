  "abuse": {
    "input_word": "abuse",
    "greek_translation": "κατάχρηση",
    "senses": [
      {
        "part_of_speech": "n",
        "definition": "cruel or inhumane treatment",
        "examples": [
          "the child showed signs of physical abuse"
        ]
      },
      {
        "part_of_speech": "n",
        "definition": "a rude expression intended to offend or hurt",
        "examples": [
          "when a student made a stupid mistake he spared them no abuse",
          "they yelled insults at the visiting team"
        ]
      },
      {
        "part_of_speech": "n",
        "definition": "improper or excessive use",
        "examples": [
          "alcohol abuse",
          "the abuse of public funds"
        ]
      },
      {
        "part_of_speech": "v",
        "definition": "treat badly",
        "examples": [
          "This boss abuses his workers",
          "She is always stepping on others to get ahead"
        ]
      },
      {
        "part_of_speech": "v",
        "definition": "change the inherent purpose or function of something",
        "examples": [
          "Don't abuse the system",
          "The director of the factory misused the funds intended for the health care of his workers"
        ]
      },
      {
        "part_of_speech": "v",
        "definition": "use foul or abusive language towards",
        "examples": [
          "The actress abused the policeman who gave her a parking ticket",
          "The angry mother shouted at the teacher"
        ]
      },
      {
        "part_of_speech": "v",
        "definition": "use wrongly or improperly or excessively",
        "examples": [
          "Her husband often abuses alcohol",
          "while she was pregnant, she abused drugs"
        ]
      }
    ],
    "status": "ok"
  },
