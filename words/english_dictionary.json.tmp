        ]
      },
      {
        "part_of_speech": "n",
        "definition": "a diacritical mark used to indicate stress or placed above a vowel to indicate a special pronunciation",
        "examples": []
      },
      {
        "part_of_speech": "v",
        "definition": "to stress, single out as important",
        "examples": [
