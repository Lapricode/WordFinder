  "abandon": {
    "input_word": "abandon",
    "greek_translation": "εγκαταλείπω",
    "senses": [
      {
        "part_of_speech": "n",
        "definition": "the trait of lacking restraint or control; reckless freedom from inhibition or worry",
        "examples": [
          "she danced with abandon"
        ]
      },
      {
        "part_of_speech": "n",
        "definition": "a feeling of extreme emotional intensity",
        "examples": [
          "the wildness of his anger"
        ]
      },
      {
        "part_of_speech": "v",
        "definition": "forsake, leave behind",
        "examples": [
          "We abandoned the old car in the empty parking lot"
        ]
      },
      {
        "part_of_speech": "v",
        "definition": "give up with the intent of never claiming again",
        "examples": [
          "Abandon your life to God",
          "She gave up her children to her ex-husband when she moved to Tahiti",
          "We gave the drowning victim up for dead"
        ]
      },
      {
        "part_of_speech": "v",
        "definition": "leave behind empty; move out of",
        "examples": [
          "You must vacate your office by tonight"
        ]
      },
      {
        "part_of_speech": "v",
        "definition": "stop maintaining or insisting on; of ideas or claims",
        "examples": [
          "He abandoned the thought of asking for her hand in marriage",
          "Both sides have to give up some claims in these negotiations"
        ]
      },
      {
        "part_of_speech": "v",
        "definition": "leave someone who needs or counts on you; leave in the lurch",
        "examples": [
          "The mother deserted her children"
        ]
      }
    ],
    "status": "ok"
  },
